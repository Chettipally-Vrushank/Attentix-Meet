    "@types/pg": "^8.11.6",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.11.5",
    "prisma": "^7.8.0"
  }
}